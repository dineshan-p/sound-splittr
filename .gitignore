# =============================================================================
# .gitignore for sound-splittr (Demucs Audio Stem Splitter)
# Based on standard Python best practices + Demucs-specific needs
# =============================================================================

# =============================================================================
# SECTION 1: PYTHON VIRTUAL ENVIRONMENT & PACKAGES - NEVER COMMIT THESE!
# =============================================================================
.venv/         # Standard Python venv directory (dot-prefixed)
venv/          # Alternative without dot prefix
env/           # Windows standard alternative
ENV/           # Linux/macOS older systems alternative
.env           # Optional environment variables file

# Poetry cache (optional, uncomment if needed):
# poetry/cache/

# PIPX user bin directory (not recommended to track)
# .local/share/pipx/

# =============================================================================
# SECTION 2: PYTHON CACHE FILES - GENERATED DURING DEVELOPMENT
# =============================================================================
__pycache__/
*.py[cod]     # Python compiled files (.pyc, .pyo)
*$py.class    # Bytecode files
*.so          # C extensions (PyTorch, librosa, torchaudio etc.)
.Python       # For Python 2 only, harmless to keep

# =============================================================================
# SECTION 3: BUILD ARTIFACTS - GENERATED DURING INSTALLATION/BUILD
# =============================================================================
dist/
build/
*.egg-info/   # setuptools metadata
.eggs/        # pip wheel cache (can be large)
pip-wheel-metadata/  # pip installation tracking
*egg-info/     # All egg-info directories (catch-all)
dist-*/       # Modern pip build directories (Python 3.8+)

# =============================================================================
# SECTION 4: DEMUCS & PYTORCH MODEL CACHE - CAN BE VERY LARGE (~500MB+ each)
# =============================================================================
cache/           # General application cache
*.pth            # PyTorch data files and model checkpoints (~500MB+ each)
app/models/      # Demucs models download directory (can be large)
tmp_models/       # Temporary model downloads during development

# =============================================================================
# SECTION 5: TEST FRAMEWORK CACHES - IMPORTANT FOR PYTHON TESTING
# =============================================================================
.pytest_cache/
.coverage       # Coverage data file
htmlcov/        # HTML coverage reports (can be large)
.tox/           # Tox virtual environments and cache
hypothesis/.generated/  # If using hypothesis testing library
coverage/       # Coverage reports directory

# =============================================================================
# SECTION 6: TYPE CHECKING & LINTING CACHES - CAN GROW LARGE
# =============================================================================
.mypy_cache/    # Mypy type checker cache (can be ~100MB+)
.ruff_cache/     # Ruff formatter/linter cache
flynt/__pycache__/  # Flynt Python formatting tool cache
pyright/         # Pyright TypeScript type checker cache
pyre/

# =============================================================================
# SECTION 7: IDE & EDITOR FILES - OPTIONAL (MOST DON'T NEED TO BE TRACKED)
# =============================================================================
.idea/          # JetBrains (IntelliJ, PyCharm, WebStorm, etc.)
.vscode/        # VS Code settings (if you want personal settings excluded)
*.swp           # Vim swap files
*.swo           # Vim backup files
.DS_Store       # macOS system files
Thumbs.db       # Windows thumbnail cache
.swf            # Sublime Text workspace
.project        # Ruby/Rails project file
.settings/      # Eclipse IDE settings

# =============================================================================
# SECTION 8: OS & SYSTEM FILES - GENERATED BY YOUR OPERATING SYSTEM
# =============================================================================
.DS_Store       # macOS Finder files (duplicate above, catch-all)
.Spotlight-V100 # macOS Spotlight index
.Trashes        # macOS trash items
.AppleDouble    # macOS hard links to .DS_Store
._*             # macOS hidden resource fork files
ehthumbs.db     # Windows Explorer thumbnail cache
Thumbs.db       # Windows thumbnail cache (duplicate above, catch-all)

# =============================================================================
# SECTION 9: LOG FILES - CAN GROW LARGE OVER TIME
# =============================================================================
*.log           # All log files
logs/           # Log directory
.log            # Root-level log file

# =============================================================================
# SECTION 10: TEST & FIXTURES (IF YOU GENERATE TEST AUDIO FILES DURING DEV)
# You can add actual test audio files to .git/info/exclude instead:
# =============================================================================
test_*_output/
*_test_output/
fixtures/generated/

# =============================================================================
# SECTION 11: TEMPORARY FILES - GENERATED DURING DEVELOPMENT/TESTING
# =============================================================================
tmp/
temp/
*.tmp           # All temporary files
*.bak            # Backup files
.swp            # Vim swap file (duplicate above)
*~               # Shell history backup files

# =============================================================================
# SECTION 12: AUDIO OUTPUT FILES (IF YOU TEST WITH REAL MUSIC)
# Consider adding these to .git/info/exclude instead of here:
# for better control over what gets ignored
# =============================================================================
outputs/        # Demo output files from testing
audio_outputs/
split_*_output/
demucs_output/
*_stems/

# =============================================================================
# SECTION 13: DOCUMENTATION & API - NOT NEEDED IN GIT BY DEFAULT
# Add if you generate docs with Sphinx, MkDocs, or similar tools:
# =============================================================================
.docbuild/
*.md.ts         # TypeScript documentation files

# =============================================================================
# SECTION 14: COVERAGE REPORTS (IF YOU RUN COVERAGE TESTS)
# Already covered in SECTION 5, but catch-all for clarity
# =============================================================================
coverage/        # Duplicate of .coverge in SECTION 5
htmlcov/         # Duplicate of htmlcov in SECTION 5
.coverage.xml    # Coverage reports in XML format
.coverage.json   # Coverage reports in JSON format

# =============================================================================
# SECTION 15: DEMUCS-SPECIFIC PATTERNS - CUSTOM FOR YOUR PROJECT
# =============================================================================
model_cache/     # Any model cache directories you use
models/.cache/   # Nested model cache (if applicable)
*.onnx           # ONNX models (if you convert Demucs models)
*.h5             # HDF5 files for audio processing

# =============================================================================
# SECTION 16: DO NOT IGNORE - THESE SHOULD BE TRACKED!
# =============================================================================
requirements.txt     # Python dependencies list (tracked in git!)
pipfile.lock         # Pipenv lock file (if you use pipenv, tracked!)
poetry.lock          # Poetry lock file (if you use poetry, tracked!)

# =============================================================================
# HOW TO USE THIS FILE:
# - Add this file to your repository with: git add .gitignore && git commit
# - For any test audio files you want to exclude, use .git/info/exclude instead:
#   (it's not tracked and can be ignored per-repository)
# - If you find patterns missing, add them at the end of this file
# =============================================================================
